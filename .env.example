# ─────────────────────────────────────────────────────────────────────────────
# metis — environment configuration
# Copy this to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# LLM provider — supported: anthropic, openai
# Aliases are normalized, so OpenAI/open_ai/open-ai and Anthropic/Claude work.
# Note: Haiku, Sonnet, GPT-4.1, etc. are model names, not provider values.
# Default: anthropic
METIS_LLM_PROVIDER=anthropic

# Anthropic API key — required when METIS_LLM_PROVIDER=anthropic
# Get one at: https://console.anthropic.com
# Note: this is a DEVELOPER account key, separate from your Claude.ai subscription.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — required when METIS_LLM_PROVIDER=openai
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Inbox connection (OAuth — recommended) ────────────────────────────────────
# Run 'metis init' to connect your inbox via browser sign-in (Gmail or Outlook).
# Tokens are stored at ~/.job_pipeline/gmail_token.json or outlook_token.json.
#
# Gmail OAuth — get credentials at console.cloud.google.com:
#   1. Create a project, enable Gmail API
#   2. APIs & Services → Credentials → Create OAuth client ID → Desktop app
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
#
# Outlook OAuth — get client ID at portal.azure.com → App registrations:
#   1. New registration → Personal Microsoft accounts only
#   2. Add redirect URI: http://127.0.0.1:8766/oauth/callback (Mobile and desktop applications)
OUTLOOK_CLIENT_ID=your-azure-app-client-id

# ── Inbox connection (IMAP fallback — legacy) ─────────────────────────────────
# Only needed if you skip OAuth. Use an App Password, NOT your Google account password.
# Step 1: Enable IMAP — mail.google.com → Settings → Forwarding and POP/IMAP → Enable IMAP
# Step 2: Generate App Password — myaccount.google.com/apppasswords (requires 2FA enabled)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send the scored digest (can be the same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=you@gmail.com

# ─── Optional ─────────────────────────────────────────────────────────────────

# Maximum number of jobs to score per run (controls API spend).
# Default: 40. Set to 0 to remove the cap and score everything in the lookback window.
# Rough cost guide: ~$0.05–0.15 per 10-job batch with claude-sonnet-4-6.
MAX_JOBS_PER_RUN=40

# How far back to look for emails on each run
# Accepts: '3d', '7d', '14d', 'yesterday', '2026-05-10'
# Default: 3d
DEFAULT_LOOKBACK=3d

# Application assistant (`metis apply`). The tailored DOCX wins when present;
# METIS_DEFAULT_RESUME is used only when a tailoring record has no usable DOCX.
METIS_DEFAULT_RESUME=/absolute/path/to/default_resume.docx
METIS_PHONE=+1-555-555-5555
METIS_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
METIS_LOCATION=City, ST
METIS_GENDER_IDENTITY=
METIS_HISPANIC_LATINO=
METIS_RACE=
METIS_VETERAN_STATUS=
METIS_DISABILITY=
METIS_WORK_AUTHORIZED=
METIS_SPONSORSHIP_REQUIRED=

# Provider-specific model settings.
# Use these when you switch providers so Anthropic and OpenAI can keep separate
# fast/full model choices in the same .env file.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_PRESCREEN_MODEL=claude-haiku-4-5
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5

OPENAI_MODEL=gpt-4.1
OPENAI_PRESCREEN_MODEL=gpt-4.1-mini
OPENAI_EXTRACT_MODEL=gpt-4.1-mini

# Backward-compatible generic model settings are also supported:
# MODEL=claude-sonnet-4-6
# PRESCREEN_MODEL=claude-haiku-4-5
# EXTRACT_MODEL=claude-haiku-4-5
