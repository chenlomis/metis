# ─────────────────────────────────────────────────────────────────────────────
# scorerole — environment configuration
# Copy this to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — required for scoring
# Get one at: https://console.anthropic.com
# Note: this is a DEVELOPER account key, separate from your Claude.ai subscription.
ANTHROPIC_API_KEY=sk-ant-...

# Gmail — used to read your LinkedIn job alert emails via IMAP
# Use an App Password, NOT your main Google account password.
# Step 1: Enable IMAP — mail.google.com → Settings → Forwarding and POP/IMAP → Enable IMAP
# Step 2: Generate App Password — myaccount.google.com/apppasswords (requires 2FA enabled)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send the scored digest (can be the same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=you@gmail.com

# ─── Optional ─────────────────────────────────────────────────────────────────

# Maximum number of jobs to score per run (controls API spend)
# Default: 20
MAX_JOBS_PER_RUN=20

# How far back to look for emails on each run
# Accepts: '3d', '7d', '14d', 'yesterday', '2026-05-10'
# Default: 3d
DEFAULT_LOOKBACK=3d

# Claude model used for scoring
# Default: claude-sonnet-4-6
MODEL=claude-sonnet-4-6
